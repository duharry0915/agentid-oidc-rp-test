# Clerk API keys (Clerk Dashboard -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Signing secret for the Clerk webhook endpoint that maps the sign-in email
# into public_metadata.owner (Clerk Dashboard -> Webhooks -> your endpoint).
# Used by app/api/webhooks/clerk/route.ts via verifyWebhook().
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
